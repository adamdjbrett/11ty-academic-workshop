{% extends "layouts/base.njk" %}

{% block nav %}
<header class="n:container r:d-none">
  <nav class="n:menu text-right">
    <input id="nav" type="checkbox" class="btn-check">
    <label for="nav" aria-label="button" class="n:icon d-inline-block m-1"></label>
    <div class="ml-3 d-none b:d-flex flex-column">
      {% for item in site.headerPages %}
        <a class="p-2" href="{{ item.url }}">{{ item.name }}</a>
      {% endfor %}
    </div>
  </nav>
</header>
{% endblock %}

{% block header %}
<header class="bg-odd{% if site.banner and site.banner.extension %} bg-{{ site.banner.extension }} bg-{{ site.banner.size }}{% if site.banner.noRepeat %} bg-no-repeat{% endif %}{% endif %}">
  <div class="container d-flex justify-center">
    <div class="header text-center px-3 py-4{% if site.banner and site.banner.fade %} fade{% endif %}">
      {% if site.title.url %}
        <a href="{% if site.title.url is string %}{{ site.title.url }}{% else %}/{% endif %}">
      {% endif %}
      <h1 id="home">{% if site.title.tagline %}<span class="tagline h3">{{ site.title.tagline }}</span> {% endif %}{{ site.title.title }}</h1>
      {% if site.title.url %}</a>{% endif %}
      {% if site.title.subtitles %}
        {% for subtitle in site.title.subtitles %}
          <h2 class="h3{% if not loop.last %} mb-2{% endif %}">{{ subtitle }}</h2>
        {% endfor %}
      {% endif %}
      {% if site.buttons %}
        <div class="d-flex flex-wrap justify-center">
          {% for button in site.buttons %}
            <a class="btn m-1" href="{{ button.url }}">{{ button.name }}</a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</header>
{% endblock %}

{% block main %}
<main aria-label="Content">
  {% block content %}
    <div class="bg-even">
      <section class="container content py-5">
        {{ content | safe }}
      </section>
    </div>
  {% endblock %}
</main>
{% endblock %}

{% block footer %}
{% if site.footerText %}
  <footer class="footer">
    {{ site.footerText | safe }}
  </footer>
{% endif %}
{% endblock %}
